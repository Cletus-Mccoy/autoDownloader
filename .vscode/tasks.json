{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup venv (local)",
            "type": "shell",
            "command": "python -m venv .venv; .venv/Scripts/pip install -r requirements.txt -q",
            "options": { "cwd": "${workspaceFolder}/app" },
            "group": "build"
        },
        {
            "label": "Test App (local)",
            "type": "shell",
            "command": "./.venv/Scripts/pytest tests -v",
            "options": { "cwd": "${workspaceFolder}/app" },
            "dependsOn": "Setup venv (local)",
            "dependsOrder": "sequence",
            "group": "test"
        },
        {
            "label": "Build Docker Image",
            "type": "shell",
            "command": "make build",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build"
        },
        {
            "label": "Test App (container)",
            "type": "shell",
            "command": "make test",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test"
        },
        {
            "label": "Test and Push",
            "type": "shell",
            "command": "make push",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build"
        }
    ]
}
