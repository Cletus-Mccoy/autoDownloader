{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup venv (local)",
            "type": "shell",
            "command": "python -m venv .venv; .venv/Scripts/pip install -r requirements.txt -q",
            "options": { "cwd": "${workspaceFolder}/app" },
            "group": "build"
        },
        {
            "label": "Test App (local)",
            "type": "shell",
            "command": "./.venv/Scripts/pytest tests -v",
            "options": { "cwd": "${workspaceFolder}/app" },
            "dependsOn": "Setup venv (local)",
            "dependsOrder": "sequence",
            "group": "test"
        },
        {
            "label": "Build Docker Image",
            "type": "shell",
            "command": "docker build --no-cache -t auto-downloader:latest ./app",
            "group": "build"
        },
        {
            "label": "Build Docker Image (cached)",
            "type": "shell",
            "command": "docker compose build",
            "options": { "cwd": "${workspaceFolder}/app" },
            "group": "build"
        },
        {
            "label": "Test App (container)",
            "type": "shell",
            "command": "docker compose run --rm ytmusic pytest tests -v",
            "options": { "cwd": "${workspaceFolder}/app" },
            "dependsOn": "Build Docker Image (cached)",
            "dependsOrder": "sequence",
            "group": "test"
        },
        {
            "label": "Test and Push",
            "type": "shell",
            "command": "docker compose build && docker compose run --rm ytmusic pytest tests -v && export $(cat ../.env | xargs) && docker build --no-cache -t auto-downloader:latest . && docker tag auto-downloader:latest $DOCKER_USER/auto-downloader:latest && docker push $DOCKER_USER/auto-downloader:latest",
            "options": { "cwd": "${workspaceFolder}/app" },
            "group": "build"
        }
    ]
}
